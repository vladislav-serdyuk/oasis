#!/bin/bash
set -euxo pipefail

# ==============================================================================
# Configuration
# ==============================================================================

# Full path to the autostart entry for runtime cleanup
AUTOSTART_FILE="$HOME/.config/autostart/oasium-bottles-init.desktop"

# Timeout configurations for the Flatpak availability check
MAX_WAIT=3600
WAIT_INTERVAL=5
ELAPSED=0

echo "Checking Bottles Flatpak availability..."

# Loop continuously until the Bottles Flatpak package is detected in the system
while ! flatpak info com.usebottles.bottles &>/dev/null; do
    if [ "$ELAPSED" -ge "$MAX_WAIT" ]; then
        echo "Error: Bottles installation timeout exceeded ($MAX_WAIT sec)." >&2
        exit 1
    fi
    sleep $WAIT_INTERVAL
    ELAPSED=$((ELAPSED + WAIT_INTERVAL))
done

COUNTRY_CODE=$(echo "$LANG" | cut -d'_' -f2 | cut -d'.' -f1)

if [ "$COUNTRY_CODE" = "RU" ]; then
    echo "Switch bottles repo to Yandex Mirror for Russian users"

    YANDEX_MIRROR="https://mirror.yandex.ru/mirrors/mirror.usebottles.com/repo"

    flatpak override --user \
        --env=PERSONAL_COMPONENTS="$YANDEX_MIRROR/components/" \
        --env=PERSONAL_DEPENDENCIES="$YANDEX_MIRROR/dependencies/" \
        --env=PERSONAL_INSTALLERS="$YANDEX_MIRROR/programs/" \
        com.usebottles.bottles

    echo "Switched"
fi

# Clean up the autostart desktop entry so it never runs again
rm -f "$AUTOSTART_FILE"
